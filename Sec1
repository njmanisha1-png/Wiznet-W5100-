<div class="product-container">
  <div class="card" *ngFor="let item of products">
    <img [src]="item.image" alt="{{item.name}}">
    <h3>{{item.name}}</h3>
    <p>₹ {{item.price}}</p>

    <div class="rating">
      <span *ngFor="let star of [1,2,3,4,5]">
        <i class="star"
           [class.filled]="star <= item.rating">★</i>
      </span>
    </div>

    <p class="sale" *ngIf="item.sale">{{item.sale}}</p>

    <button (click)="addToCart(item)">Order Now</button>
  </div>
</div>
.product-container {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px,1fr));
  gap: 20px;
  padding: 20px;
}

.card {
  border-radius: 15px;
  padding: 15px;
  text-align: center;
  box-shadow: 0 4px 8px rgba(0,0,0,0.1);
}

.card img {
  width: 100%;
  height: 200px;
  object-fit: cover;
}

.star {
  font-size: 20px;
  color: gray;
}

.filled {
  color: gold;
}

.sale {
  color: red;
  font-weight: bold;
}
cart: any[] = [];

addToCart(product: any) {
  this.cart.push(product);
  alert("Product Added to Cart");
}
